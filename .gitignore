# Environments
.venv/
venv/
ENV/
env/
.env

# Python
__pycache__/
*.py[cod]
*$py.class

# Node
node_modules/
dist/
build/

# Local Config & Data
data/knowledge-graph/
data/output/
config/llm-config.yaml
config/founder-auth.yaml
*.db
*.sqlite3

# OS
.DS_Store
Thumbs.db

# Project-specific
temp-gsd/
_xlsx_info.txt
_gsd/

# Content Studio uploads (user data, synced separately)
data/founders/*/podcast-data/
data/founders/*/studio-docs/
data/founders/*/blog-data/

# Founder data caches (rebuilt on first run; never deploy stale cache)
data/founders/*/.ingestion_cache.json
data/founders/*/.internalization_cache.json
data/founders/*/.migration_cache.json

# Models config (synced to VPS via /api/admin/models/sync endpoint)
config/models-config.json
data/founders/*/config/models-override.json

# Migration sandboxes (transient; promoted via `--commit` which renames to <slug>)
data/founders/*_v2/
data/founders/*_pre_migration_*/

# Run-history bulk artifacts (5MB+ per run; keep run-log.md and coverage/)
data/founders/*/run-history/handoffs/
data/founders/*/run-history/verbose-logs/

# SSH keys (never commit private keys!)
hostinger_mcp
hostinger_mcp.pub
*.pem
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Local Claude settings
.claude/settings.local.json

# Screenshots / debug images
images/
